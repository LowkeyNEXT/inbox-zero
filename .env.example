# Inbox Zero — Self-Hosted Environment Config
# Copy to .env and fill in values before deploying

# =============================================================================
# CORE
# =============================================================================
# Public URL where Inbox Zero will be accessible (use your reverse proxy URL)
NEXT_PUBLIC_BASE_URL=https://inbox.yourdomain.com

# =============================================================================
# SECRETS — Generate each with: openssl rand -hex 32
#           (except SALT which uses: openssl rand -hex 16)
# =============================================================================
AUTH_SECRET=
INTERNAL_API_KEY=
EMAIL_ENCRYPT_SECRET=
EMAIL_ENCRYPT_SALT=
UPSTASH_REDIS_TOKEN=
CRON_SECRET=

# =============================================================================
# DATABASE — Auto-configured when using docker compose --profile all
# Only set these if using an external database
# =============================================================================
# DATABASE_URL=postgresql://inbox_zero:password@db:5432/inbox_zero
# DIRECT_URL=postgresql://inbox_zero:password@db:5432/inbox_zero

# =============================================================================
# LLM — Ollama (Primary)
# =============================================================================
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
# Replace with your Ollama VM's IP address
OLLAMA_BASE_URL=http://OLLAMA_VM_IP:11434/api

# LLM — Economy model (for high-volume/simple tasks)
ECONOMY_LLM_PROVIDER=ollama
ECONOMY_LLM_MODEL=qwen3:1.7b

# =============================================================================
# GOOGLE OAUTH (Gmail)
# https://console.cloud.google.com/apis/credentials
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC_NAME=projects/YOUR_PROJECT/topics/gmail-inbox-zero

# =============================================================================
# MICROSOFT OAUTH (Outlook)
# https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# =============================================================================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
NEXT_PUBLIC_BYPASS_PREMIUM_CHECKS=true
NEXT_PUBLIC_EMAIL_SEND_ENABLED=true
